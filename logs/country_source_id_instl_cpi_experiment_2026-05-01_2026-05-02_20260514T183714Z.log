WITH campaign_data AS (
    SELECT
        id AS campaign_id,
        application_id,
        MAP(
            TRANSFORM(CAST(goal_events AS ARRAY(JSON)), x -> CAST(JSON_EXTRACT(x, '$.event_id') AS INT)),
            TRANSFORM(CAST(goal_events AS ARRAY(JSON)), x -> CAST(JSON_EXTRACT(x, '$.weight') AS DOUBLE))
        ) AS event_weights
    FROM mysql.ruby3.campaigns c
    WHERE goal_type = 'CPI'
        AND MOD(c.id, 2) = 0
),
install_counts AS (
    SELECT
        ins.campaign_id,
        ins.trans_id,
        COUNT(*) AS install_total
    FROM dw.installs ins
    JOIN campaign_data cd ON ins.campaign_id = cd.campaign_id
    WHERE ins.dt BETWEEN '2026-05-01-00' AND '2026-05-09-23'
        AND ins.install_created IS NOT NULL
    GROUP BY 1, 2
)
SELECT
    substring(imp.dt, 1, 10) AS day,
    element_at(imp.bid_request_info, 'ctry2') AS country_code,
                CAST(imp.source_id AS varchar) AS source_id,
                CAST(element_at(imp.impression_args, 'instl') AS varchar) AS instl,
    imp.campaign_id,
    imp.app_id,
    SUM(imp.impression_price * (1 + imp.fee) / 1000) AS spend,
    COALESCE(SUM(ins.install_total), 0) AS total_installs,
    COUNT(imp.trans_id) AS impressions,
    COUNT(DISTINCT imp.device_id) AS imp_devices
FROM dw.enriched_impressions imp
LEFT JOIN install_counts ins ON imp.trans_id = ins.trans_id
WHERE imp.dt BETWEEN '2026-05-01-00' AND '2026-05-02-23'
    AND imp.campaign_id IN (SELECT campaign_id FROM campaign_data)
    AND imp.source_id IS NOT NULL AND element_at(imp.impression_args, 'instl') IS NOT NULL
GROUP BY 1, 2, 3, 4, 5, 6
ORDER BY 1, 5, spend DESC
